{
  "name": "besserlesenschreiben-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Adaptive German children's literacy tutor — frontend SPA/PWA",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:api": "openapi-typescript http://localhost:3000/api/v1/openapi.json -o src/lib/api.gen.ts"
  },
  "dependencies": {
    "@fontsource-variable/bricolage-grotesque": "^5",
    "@fontsource/atkinson-hyperlegible": "^5",
    "@tanstack/react-query": "^5",
    "class-variance-authority": "^0.7",
    "clsx": "^2",
    "lucide-react": "^1",
    "react": "^19.2",
    "react-dom": "^19.2",
    "react-router-dom": "^7",
    "tailwind-merge": "^3"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@tailwindcss/vite": "^4.3",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24",
    "@types/react": "^19.2",
    "@types/react-dom": "^19.2",
    "@vitejs/plugin-react": "^6",
    "eslint": "^9",
    "jsdom": "^25",
    "openapi-typescript": "^7",
    "tailwindcss": "^4.3",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vite": "^8.1",
    "vite-plugin-pwa": "^1",
    "vitest": "^4"
  }
}
