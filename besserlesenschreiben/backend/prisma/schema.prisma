// besserlesenschreiben — Prisma schema. The canonical system of record (backend SPEC §3).
// Wire format is camelCase; DB columns are snake_case (bridged via @map/@@map).

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ── ACCOUNT (household, keyed by parent email) ───────────────────────────────
model Account {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  // Access lifecycle (ARCHITECTURE §1b): pending → active → deactivated. A first login-code request
  // creates a `pending` account and emails NOTHING; a staff admin approves before the first code is sent.
  // The family JwtAuthGuard requires `active` per-request, so deactivate/delete take effect immediately.
  status        String   @default("pending") @map("status") // pending | active | deactivated
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  profiles   Profile[]
  loginCodes LoginCode[]

  @@map("account")
}

// ── LOGIN CODES (passwordless) ───────────────────────────────────────────────
model LoginCode {
  id         String    @id @default(uuid()) @db.Uuid
  accountId  String?   @map("account_id") @db.Uuid
  email      String
  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  account Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([email])
  @@map("login_code")
}

// ── PROFILE (a student) ──────────────────────────────────────────────────────
model Profile {
  id           String   @id @default(uuid()) @db.Uuid
  accountId    String   @map("account_id") @db.Uuid
  name         String
  buddy        String   @default("nepo") // nepo | stella
  goalPerWeek  Int      @default(5) @map("goal_per_week")
  // accessibility / settings
  soundOn      Boolean  @default(true) @map("sound_on")
  dyslexicFont Boolean  @default(false) @map("dyslexic_font")
  fontScale    Decimal  @default(1.0) @map("font_scale") @db.Decimal(3, 2)
  // gamification & progression state
  stars        Int      @default(0)
  streakDays   Int      @default(0) @map("streak_days")
  lastActive   DateTime? @map("last_active") @db.Date
  jokerUsedWeek DateTime? @map("joker_used_week") @db.Date
  unlockedUnit Int      @default(1) @map("unlocked_unit")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  account      Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sessions     Session[]
  attempts     Attempt[]
  reviewStates ReviewState[]
  homework     HomeworkUpload[]
  chatMessages ChatMessage[]

  @@index([accountId])
  @@map("profile")
}

// ── ITEM BANK (global, shared) ───────────────────────────────────────────────
model ItemBank {
  id            String   @id @default(uuid()) @db.Uuid
  seedKey       String?  @unique @map("seed_key")
  unit          Int
  exerciseType  String   @map("exercise_type")
  payload       Json
  audioUrl      String?  @map("audio_url")
  syllableAudio Json?    @map("syllable_audio")
  skillTags     String[] @map("skill_tags")
  difficulty    Int      @default(1)
  generatedBy   String   @default("seed") @map("generated_by")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  attempts Attempt[]

  @@index([unit])
  @@map("item_bank")
}

// Lexeme (the annotated word foundation) was dropped along with the Vokaltraining content set — the
// word-list schema, training types, sequence, and lecture-generation approach are being redesigned from
// scratch. Re-add as a fresh model when the new approach's word-list shape is decided.

// ── SESSION (a generated training session) ───────────────────────────────────
model Session {
  id          String    @id @default(uuid()) @db.Uuid
  profileId   String    @map("profile_id") @db.Uuid
  unit        Int?
  itemIds     String[]  @map("item_ids") @db.Uuid
  source      String // 'bank' | 'llm' | 'homework'
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  starsAward  Int?      @map("stars_award")

  profile  Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  attempts Attempt[]

  @@index([profileId])
  @@map("session")
}

// ── ATTEMPT (THE telemetry table — one row per answered item) ────────────────
model Attempt {
  id           String   @id @default(uuid()) @db.Uuid
  profileId    String   @map("profile_id") @db.Uuid
  sessionId    String   @map("session_id") @db.Uuid
  itemId       String?  @map("item_id") @db.Uuid
  exerciseType String   @map("exercise_type")
  prompt       String
  expected     String
  given        String
  isCorrect    Boolean  @map("is_correct")
  timeMs       Int      @map("time_ms")
  attemptNo    Int      @default(1) @map("attempt_no")
  skillTags    String[] @map("skill_tags")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  profile Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  session Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  item    ItemBank? @relation(fields: [itemId], references: [id])

  // NOTE (ARCHITECTURE §4): idempotency dedupe on (session_id, item_id, attempt_no) needs a
  // functional unique index with COALESCE(item_id, '0…0') because item_id is nullable and NULLs
  // are distinct in Postgres. Added as raw SQL in the migration, not expressible here.
  @@index([profileId])
  @@index([sessionId])
  @@map("attempt")
}

// ── FSRS scheduling state (one row per profile × skill_tag) ──────────────────
model ReviewState {
  id            String    @id @default(uuid()) @db.Uuid
  profileId     String    @map("profile_id") @db.Uuid
  skillTag      String    @map("skill_tag")
  stability     Decimal?
  difficulty    Decimal?
  state         Int       @default(0) // 0=new 1=learning 2=review 3=relearning
  reps          Int       @default(0)
  lapses        Int       @default(0)
  learningSteps Int       @default(0) @map("learning_steps") // ts-fsrs step index; persisted so mid-learning isn't reset
  elapsedDays   Int       @default(0) @map("elapsed_days")
  scheduledDays Int       @default(0) @map("scheduled_days")
  due           DateTime? @db.Timestamptz(6)
  lastReview    DateTime? @map("last_review") @db.Timestamptz(6)

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, skillTag])
  @@index([profileId, due])
  @@map("review_state")
}

// ── HOMEWORK uploads + analysis ──────────────────────────────────────────────
model HomeworkUpload {
  id        String @id @default(uuid()) @db.Uuid
  profileId String @map("profile_id") @db.Uuid
  imageKey  String @map("image_key")
  // pending_analysis | pending_review | reviewed | rejected
  status    String @default("pending_analysis")

  llmAnalysis      Json?     @map("llm_analysis") // DRAFT vision output — NEVER applied on its own
  reviewedAnalysis Json?     @map("reviewed_analysis") // AUTHORITATIVE; only this mutates the learning profile
  reviewerId       String?   @map("reviewer_id") @db.Uuid // who actioned it (null until reviewed)
  reviewDecision   String?   @map("review_decision") // approved|corrected|rejected
  reviewedAt       DateTime? @map("reviewed_at") @db.Timestamptz(6)
  appliedAt        DateTime? @map("applied_at") @db.Timestamptz(6) // when reviewedAnalysis hit attempt/review_state
  claimedBy        String?   @map("claimed_by") @db.Uuid // soft-lock so two reviewers don't grab the same item
  claimedUntil     DateTime? @map("claimed_until") @db.Timestamptz(6) // claim lease expiry (auto-released)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  profile  Profile          @relation(fields: [profileId], references: [id], onDelete: Cascade)
  reviewer Reviewer?        @relation("ReviewerActioned", fields: [reviewerId], references: [id])
  claimant Reviewer?        @relation("ReviewerClaimed", fields: [claimedBy], references: [id])
  reviews  HomeworkReview[]

  @@index([profileId])
  @@index([status]) // queue scan for pending_review
  @@map("homework_upload")
}

// ── STAFF realm: internal literacy professionals (ARCHITECTURE §1a) ──────────
// DISJOINT identity from Account/Profile — a staff credential is never valid in the family realm.
model Reviewer {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique // staff login (never a family email)
  name      String
  role      String   @default("reviewer") // reviewer|admin
  status    String   @default("active") // active|revoked
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actioned HomeworkUpload[] @relation("ReviewerActioned")
  claimed  HomeworkUpload[] @relation("ReviewerClaimed")
  reviews  HomeworkReview[]

  @@map("reviewer")
}

// ── STAFF login codes (passwordless, disjoint from family login_code) ─────────
// Separate table so a staff code can never be consumed by a family verify and vice-versa, even if an
// email somehow appears in both realms. Staff are admin-provisioned (no self-signup) — request-code only
// issues a code when an active reviewer owns the email, but always returns ok (no enumeration).
model StaffLoginCode {
  id         String    @id @default(uuid()) @db.Uuid
  email      String
  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([email])
  @@map("staff_login_code")
}

// ── HOMEWORK review audit (append-only) ──────────────────────────────────────
// Retains the LLM draft + reviewer verdict so vision quality is measurable ("compare vs LLM", SPEC §10).
model HomeworkReview {
  id               String   @id @default(uuid()) @db.Uuid
  uploadId         String   @map("upload_id") @db.Uuid
  reviewerId       String   @map("reviewer_id") @db.Uuid
  decision         String // approved|corrected|rejected
  llmAnalysis      Json     @map("llm_analysis") // snapshot of the draft shown to the reviewer
  reviewedAnalysis Json?    @map("reviewed_analysis") // the verdict (null when rejected)
  agreedWithLlm    Boolean  @map("agreed_with_llm") // false ⇒ reviewer changed something (LLM-quality signal)
  notes            String? // optional reviewer comment — STUDENT-VISIBLE (chat status bubble); never student-identifying
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  upload   HomeworkUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  reviewer Reviewer       @relation(fields: [reviewerId], references: [id])

  @@index([uploadId])
  @@index([reviewerId])
  @@map("homework_review")
}

// ── CHAT (trainer conversation thread, per student profile) ──────────────────
model ChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  profileId String   @map("profile_id") @db.Uuid
  role      String // 'student' | 'trainer' (read path also tolerates legacy 'child' rows)
  text      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("chat_message")
}

// Billing (entitlement / credits_ledger / processed_webhook) is DEFERRED and its tables were dropped
// (ARCHITECTURE §9). Re-add them by migration if metering is ever introduced.
