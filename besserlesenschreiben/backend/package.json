{
  "name": "besserlesenschreiben-api",
  "version": "0.1.0",
  "private": true,
  "description": "Adaptive German children's literacy tutor — backend API",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "prisma db seed",
    "seed:e2e": "tsx scripts/seed-e2e.ts",
    "export:overrides": "tsx scripts/export-overrides.ts",
    "gen:items": "tsx scripts/gen-items-from-lexemes.ts",
    "openapi:export": "tsx scripts/export-openapi.ts",
    "llm:smoke": "tsx scripts/llm-smoke.ts",
    "prisma:generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0",
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^9.1.3",
    "@nestjs/common": "^11",
    "@nestjs/config": "^4",
    "@nestjs/core": "^11",
    "@nestjs/jwt": "^11",
    "@nestjs/platform-fastify": "^11",
    "@nestjs/swagger": "^11",
    "@prisma/adapter-pg": "^7",
    "@prisma/client": "^7",
    "argon2": "^0.43",
    "dotenv": "^17.4.2",
    "nestjs-pino": "^4",
    "pino-http": "^10",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "sharp": "^0.34.5",
    "ts-fsrs": "^5.4.1",
    "zod": "^4"
  },
  "devDependencies": {
    "@nestjs/cli": "^11",
    "@nestjs/schematics": "^11",
    "@nestjs/testing": "^11",
    "@swc/core": "^1",
    "@types/node": "^24",
    "eslint": "^9",
    "pino-pretty": "^13",
    "prisma": "^7",
    "tsx": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "unplugin-swc": "^1",
    "vitest": "^3"
  },
  "allowScripts": {
    "argon2@0.43.1": true,
    "esbuild@0.28.1": true,
    "prisma@7.8.0": true,
    "@prisma/engines@7.8.0": true,
    "@swc/core@1.15.43": true,
    "@scarf/scarf@1.4.0": true,
    "fsevents@2.3.3": true
  }
}
