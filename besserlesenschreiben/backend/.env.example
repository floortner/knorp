# ---------------------------------------------------------------------------
# besserlesenschreiben backend — example environment.  Copy to `.env`:  cp .env.example .env
#
# Validated at boot by a Zod env schema (@nestjs/config) — the app fails fast if a required var
# is missing (SPEC §11). NEVER commit a real secret; in prod these come from Azure Key Vault.
#
# MILESTONE 1 (auth + profiles + parent PIN) needs ONLY:
#   NODE_ENV, PORT, DATABASE_URL, JWT_SECRET, EMAIL_PROVIDER=console
# Everything below the line is for later milestones and can stay blank until then.
# ---------------------------------------------------------------------------

NODE_ENV=development
PORT=3000

# Postgres — matches the role/db you create in the README's first-time setup
DATABASE_URL=postgresql://blsb:devpass@localhost:5432/blsb_dev

# Session JWT signing secret (family realm). Dev-only value here; real secret via Key Vault in prod.
JWT_SECRET=dev-only-change-me

# Staff realm (reviewer portal) JWT signing secret — MUST differ from JWT_SECRET (ARCHITECTURE §1a).
STAFF_JWT_SECRET=dev-only-staff-change-me
# Reviewer portal origin for CORS (blank → reflect any origin in dev). e.g. https://review.blesen.app
REVIEWER_ORIGIN=
# Admin bootstrap: comma-separated emails seeded as active admin reviewers (no staff self-signup).
# Set to the owner's email so someone can approve/deactivate/delete families. e.g. owner@example.com
STAFF_ADMIN_EMAILS=
# Homework review queue soft-lock lease in seconds (default 900 = 15 min).
HOMEWORK_REVIEW_CLAIM_TTL=900

# Login-code email delivery. `console` = dev stub that PRINTS the 4-digit code to stdout
# (no real email server needed locally). Use `resend` in prod (requires EMAIL_KEY + EMAIL_FROM).
EMAIL_PROVIDER=console
EMAIL_KEY=
# Sender identity for non-console providers, e.g. "besserlesenschreiben <login@blesen.app>".
EMAIL_FROM=

# --- later milestones (leave blank for milestone 1) ------------------------

# LLM — chat, LLM sessions, homework vision (free; abstracted LlmService). See ../ARCHITECTURE.md §8.
# Leave ANTHROPIC_API_KEY blank in dev → a stub provider (canned chat; structured calls 503). Set it for
# real Anthropic-direct. In PRODUCTION a key also requires LLM_RESIDENCY_ACK=true (EU data-flow/DPA ack).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6     # configurable; current default
LLM_RESIDENCY_ACK=                    # set to 'true' in prod to acknowledge the EU data-flow before LLM calls

# Object storage — per-user prefixes. Set AZURE_STORAGE_ACCOUNT to use Azure Blob (auth via Managed
# Identity, no keys in env); leave blank to use the local-filesystem fake. CONTAINER is required when
# ACCOUNT is set. (Per-user SAS URL minting for homework photos lands with the homework milestone.)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=
# Dev-only: where the local-filesystem Blob fake writes (digest.md, etc.). Blank → <os tmpdir>/blsb-dev-blob.
STORAGE_LOCAL_DIR=

# Neural TTS (de-AT preferred, de-DE fine). Pre-generated per item, cached in Blob.
TTS_PROVIDER=
TTS_KEY=

# Payments — Merchant of Record. Webhook is the source of truth, verified by this secret.
BILLING_PROVIDER=lemonsqueezy         # lemonsqueezy|paddle
BILLING_WEBHOOK_SECRET=
