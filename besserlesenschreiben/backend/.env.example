# ---------------------------------------------------------------------------
# besserlesenschreiben backend — example environment.  Copy to `.env`:  cp .env.example .env
#
# Validated at boot by a Zod env schema (@nestjs/config) — the app fails fast if a required var
# is missing (SPEC §11). NEVER commit a real secret; in prod these come from Azure Key Vault.
#
# MILESTONE 1 (auth + profiles + parent PIN) needs ONLY:
#   NODE_ENV, PORT, DATABASE_URL, JWT_SECRET, EMAIL_PROVIDER=console
# Everything below the line is for later milestones and can stay blank until then.
# ---------------------------------------------------------------------------

NODE_ENV=development
PORT=3000

# Postgres — matches the role/db you create in the README's first-time setup
DATABASE_URL=postgresql://blsb:devpass@localhost:5432/blsb_dev

# Session JWT signing secret. Dev-only value here; real secret via Key Vault in prod.
JWT_SECRET=dev-only-change-me

# Login-code email delivery. `console` = dev stub that PRINTS the 4-digit code to stdout
# (no real email server needed locally). Use a real provider (acs|resend|postmark) in prod.
EMAIL_PROVIDER=console
EMAIL_KEY=

# --- later milestones (leave blank for milestone 1) ------------------------

# LLM — chat, LLM sessions, homework vision (★ gated). See ../ARCHITECTURE.md §8.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6     # configurable; current default

# Object storage — per-user prefixes + SAS URLs. In prod, auth via Managed Identity (no keys
# in env); in dev a local-filesystem fake stands in until the real adapter lands.
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=

# Neural TTS (de-AT preferred, de-DE fine). Pre-generated per item, cached in Blob.
TTS_PROVIDER=
TTS_KEY=

# Payments — Merchant of Record. Webhook is the source of truth, verified by this secret.
BILLING_PROVIDER=lemonsqueezy         # lemonsqueezy|paddle
BILLING_WEBHOOK_SECRET=
